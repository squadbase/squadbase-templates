    "@types/pg": "^8.16.0",
    "@types/snowflake-sdk": "^1.6.24",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "~5.7.0",
    "vite": "^7.0.0"
  }
